# ----------------------------------------------------------------------------
# Luna Rosa — environment variables
# Production'da .env.production veya host paneli (Vercel/Netlify/Plesk) uzerinden tanimlayin.
# ----------------------------------------------------------------------------

# Admin paneli — ikisini de doldurmadiginiz surece /admin koruma SIZ DEVRE DISI olur,
# fakat URL'yi bilen herkes panele erisebilir. Canliya almadan once mutlaka doldurun.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Rastgele 32+ byte hex bir deger uretin (ornek: openssl rand -hex 32)
ADMIN_SESSION_TOKEN=

# Admin verisi (urun/siparis/ayar) bu klasore JSON olarak yazilir.
# Default: <proje>/.data — kalici disk olan host'ta calisir. Read-only ortamda mock olarak bellekte tutulur.
# ADMIN_DB_DIR=/var/data/luna-rosa

# Site URL (sitemap, robots, OG tags) — son slash olmadan
NEXT_PUBLIC_SITE_URL=https://www.lunarosa.com.tr

# Iletisim & sosyal medya (footer + mobil menu + WhatsApp butonu)
NEXT_PUBLIC_WHATSAPP_PHONE=905550000000
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/lunarosa
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/lunarosa
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@lunarosa
