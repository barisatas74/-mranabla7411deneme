# ============================================================================
# Miss Bella — Ortam Değişkenleri
# ============================================================================
# Production'da .env.production veya host paneli (Vercel / Plesk / VPS)
# üzerinden tanımlayın. Bu dosyayı asla commit etmeyin (zaten .gitignore'da).
# ============================================================================

# ----------------------------------------------------------------------------
# 🔒 ADMIN PANELİ (zorunlu — yayına çıkmadan önce doldurun)
# ----------------------------------------------------------------------------
# İkisini de doldurmadığınız sürece /admin koruma SIZ DEVRE DISI olur,
# fakat URL'yi bilen herkes panele erişebilir.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Cookie imzası için rastgele 32+ byte hex değer.
# Üretmek için: openssl rand -hex 32
ADMIN_SESSION_TOKEN=

# ----------------------------------------------------------------------------
# 💾 VERİTABANI (MySQL / MariaDB)
# ----------------------------------------------------------------------------
# DB_TYPE=mysql doldurulursa mock yerine gercek veritabani kullanilir.
# Bos birakilirsa mock (bellek) servisleri devreye girer.
DB_TYPE=mysql

# Hosting'inizden aldiginiz baglanti bilgileri:
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
# Bazi hosting saglayicilari SSL zorunlu kilar. Gerekiyorsa "true" yapin.
DB_SSL=false

# Supabase / PostgreSQL (alternatif — kullanmiyorsaniz bos birakin)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# 🌐 SİTE BİLGİLERİ (zorunlu)
# ----------------------------------------------------------------------------
# Sitemap, robots, OG tags ve canonical URL için kullanılır. Son slash YOK.
NEXT_PUBLIC_SITE_URL=https://www.missbellalingree.com

# ----------------------------------------------------------------------------
# 📞 İLETİŞİM & SOSYAL MEDYA (opsiyonel — boş kalanlar görünmez)
# ----------------------------------------------------------------------------
# Sadece rakam, ülke kodu dahil (örn: 905551112233)
NEXT_PUBLIC_WHATSAPP_PHONE=

# Müşteri hizmetleri telefonu (footer + iletişim sayfasında gösterilir)
NEXT_PUBLIC_SUPPORT_PHONE=

# Müşteri hizmetleri e-postası
NEXT_PUBLIC_SUPPORT_EMAIL=

# Sosyal medya URL'leri (boş ise footer'da görünmez)
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_TIKTOK_URL=

# ----------------------------------------------------------------------------
# 💳 ÖDEME ENTEGRASYONU (host kurulumunda eklenecek)
# ----------------------------------------------------------------------------
# iyzico
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://api.iyzipay.com

# Stripe
# STRIPE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# PayTR
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=

# ----------------------------------------------------------------------------
# 📧 E-POSTA PROVIDER (opsiyonel — sipariş bildirimleri için)
# ----------------------------------------------------------------------------
# Resend (önerilen)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=info@missbellalingree.com

# Sendgrid alternatif
# SENDGRID_API_KEY=

# ----------------------------------------------------------------------------
# 📊 ANALYTICS & İZLEME (opsiyonel)
# ----------------------------------------------------------------------------
# Google Analytics 4
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Vercel Analytics otomatik (ayar gerekmez)

# Sentry hata izleme
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
